{
  "_comment": "Copy to secrets.local.json (gitignored) and fill in. Run scripts/sync_render_env.py to push every non-empty value to Render as an env var. Keys starting with '_' are meta (used by the script, never pushed). Leave a value as \"\" to skip it (e.g. let Render generate SESSION_SECRET). The JSON is host-agnostic — moving off Render means a new sync script, not new secrets.",

  "_render_api_key": "",
  "_render_service_name": "backtick",
  "_render_service_id": "",

  "ENV": "production",
  "DATABASE_URL": "sqlite+aiosqlite:////var/data/backtick.db",
  "DATA_CACHE_DIR": "/var/data/data_cache",

  "SESSION_SECRET": "",

  "GOOGLE_CLIENT_ID": "",
  "GOOGLE_CLIENT_SECRET": "",

  "APPLE_CLIENT_ID": "",
  "APPLE_TEAM_ID": "",
  "APPLE_KEY_ID": "",
  "APPLE_PRIVATE_KEY": "",

  "R2_ACCOUNT_ID": "",
  "R2_ACCESS_KEY_ID": "",
  "R2_SECRET_ACCESS_KEY": "",
  "R2_BUCKET": "",
  "R2_PREFIX": ""
}
